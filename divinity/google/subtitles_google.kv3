		"turret.sp_sabotage_factory_defect_fail09" = "<font color=\"rgb(197,208,230)\"><low>Defective Turret: Well, can't win 'em all..."
		"turret.sp_sabotage_factory_defect_fail10" = "<font color=\"rgb(197,208,230)\"><low>Defective Turret: Nooooooooo..."
