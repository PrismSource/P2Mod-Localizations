		"turret.sp_sabotage_factory_defect_test04" = "<font color=\"rgb(197,208,230)\"><low>Defective Turret: Yeah, what?"
		"turret.sp_sabotage_factory_defect_test05" = "<font color=\"rgb(197,208,230)\"><low>Defective Turret: Yeah! Let's do this!"
