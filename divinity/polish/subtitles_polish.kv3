		"turret.finale02_turret_return_defect_fail11" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Co tu trzeba zrobić, żeby dostać naboje?"
		"turret.finale02_turret_return_defect_fail12" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: No na litość boską!"
		"turret.finale02_turret_return_defect_fail13" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nie. Nadal nic nie widzę."
		"turret.finale02_turret_return_defect_fail14" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak jest. Nadal ślepy."
		"turret.finale02_turret_return_defect_fail15" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Klik klik klik! Nadal wadliwy!"
		"turret.finale02_turret_return_defect_fail16" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak jest, zgadza się! Nadal wadliwy!"
		"turret.finale02_turret_return_defect_fail17" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: No! Nadal nie działam."
