		"turret.sp_sabotage_factory_defect_laugh06" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: He he he he..."
		"turret.sp_sabotage_factory_defect_laugh07" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: O tak! Ha ha ha!"
		"turret.sp_sabotage_factory_defect_pass01" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: He he he..."
		"turret.sp_sabotage_factory_defect_pass02" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Naprawdę? W porządku."
		"turret.sp_sabotage_factory_defect_pass03" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: W rzeczy samej. W rzeczy samej."
		"turret.sp_sabotage_factory_defect_pass04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Dobra. Twój pogrzeb, koleś."
		"turret.sp_sabotage_factory_defect_pass05" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Czyli... wszyscy mamy być ślepi, tak? Nie tylko ja jeden? Dobra, super."
		"turret.sp_sabotage_factory_defect_pass06" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Ja... eee... nie mam nabojów. Dasz mi naboje? A może są tam na górze?"
		"turret.sp_sabotage_factory_defect_pass07" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Gdzie dostanę broń?"
		"turret.sp_sabotage_factory_defect_pass08" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Czy my... eee... dostaniemy może oczy? Bo nic nie widzę."
		"turret.sp_sabotage_factory_defect_pass09" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: O tak, jestem twardzielem!"
		"turret.sp_sabotage_factory_defect_pass10" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Ja... eee... jestem twardzielem."
		"turret.sp_sabotage_factory_defect_postrange01" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Dałem z siebie wszystko. Więcej wymagać nie można."
		"turret.sp_sabotage_factory_defect_postrange02" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Eeee... Bam! Bam bam bam! Nie jestem wadliwy!"
		"turret.sp_sabotage_factory_defect_postrange03" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Zrobiłem, co mogłem."
		"turret.sp_sabotage_factory_defect_postrange04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: A nie, ja jestem jednym z tych złych, nie?"
		"turret.sp_sabotage_factory_defect_postrange05" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Hej! Piskliwy głosik! Daj mi naboje!"
		"turret.sp_sabotage_factory_defect_postrange06" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Dostanę tu jakieś naboje? Ma ktoś naboje?"
		"turret.sp_sabotage_factory_defect_postrange07" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Ma ktoś naboje?"
		"turret.sp_sabotage_factory_defect_postrange08" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Przynajmniej spróbowałem."
		"turret.sp_sabotage_factory_defect_postrange09" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Eeee, nie mam nabojów. Niestety."
		"turret.sp_sabotage_factory_defect_postrange10" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nie na rady."
		"turret.sp_sabotage_factory_defect_postrange11" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Eeee, nie mam nabojów. Niestety."
		"turret.sp_sabotage_factory_defect_postrange12" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Hej! Piskliwy głosik! Jak mi poszło?"
		"turret.sp_sabotage_factory_defect_postrange13" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: TAK JEST! Co się dzieje?"
		"turret.sp_sabotage_factory_defect_postrange14" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak właśnie, udało mi się, prawda?"
		"turret.sp_sabotage_factory_defect_postrange15" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak jest."
		"turret.sp_sabotage_factory_defect_postrange16" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak jest."
		"turret.sp_sabotage_factory_defect_postrange17" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Trafiłem? Trafiłem, prawda?"
		"turret.sp_sabotage_factory_defect_postrange18" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: O tak. Kliku klik klik. Tak ma być."
		"turret.sp_sabotage_factory_defect_postrange19" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Walimy ślepakami, zawsze i wszędzie."
		"turret.sp_sabotage_factory_defect_postrange20" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak właśnie, strzał w dziesiątkę."
		"turret.sp_sabotage_factory_defect_postrange21" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Co trafiłem?"
		"turret.sp_sabotage_factory_defect_postrange22" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: W końcu nie można zawsze wygrywać."
		"turret.sp_sabotage_factory_defect_postrange23" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Jak mi poszło?"
		"turret.sp_sabotage_factory_defect_postrange24" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Spocznij."
		"turret.sp_sabotage_factory_defect_postrange25" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Kłopoty to ja."
		"turret.sp_sabotage_factory_defect_prerange01" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Patrzcie i uczcie się. Patrzcie i uczcie."
		"turret.sp_sabotage_factory_defect_prerange02" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Dobra, patrzcie na to."
		"turret.sp_sabotage_factory_defect_prerange03" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: W porządku, wszyscy się cofnąć."
		"turret.sp_sabotage_factory_defect_prerange04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Teraz zobaczycie mistrza."
		"turret.sp_sabotage_factory_defect_prerange05" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Patrzcie i uczcie się. Patrzcie i uczcie."
		"turret.sp_sabotage_factory_defect_prerange06" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Co ja... co ja tu mam zrobić?"
		"turret.sp_sabotage_factory_defect_prerange07" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Zidentyfikuj się albo będę strzelać!"
		"turret.sp_sabotage_factory_defect_test01" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Czołem."
		"turret.sp_sabotage_factory_defect_test02" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Hej, jak leci?"
		"turret.sp_sabotage_factory_defect_test03" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Miło poznać."
		"turret.sp_sabotage_factory_defect_test04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: No co?"
		"turret.sp_sabotage_factory_defect_test05" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: O tak! Do dzieła!"
		"turret.sp_sabotage_factory_defect_test06" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Kto to powiedział?"
		"turret.sp_sabotage_factory_defect_test07" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: No co?"
		"turret.sp_sabotage_factory_defect_test08" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Trenerze, dopuść mnie do gry!"
		"turret.sp_sabotage_factory_defect_test09" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Cześć. Cze... o szlag..."
		"turret.sp_sabotage_factory_defect_test10" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Hej, czołem, jak leci?"
		"turret.sp_sabotage_factory_defect_test11" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Będziecie ze mnie dumni!"
		"turret.sp_sabotage_factory_defect_test12" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Hej, jak leci?"
		"turret.sp_sabotage_factory_defect_test13" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Em."
		"turret.sp_sabotage_factory_defect_test14" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Czołem."
		"turret.sp_sabotage_factory_defect_test15" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Cholera."
		"turret.sp_sabotage_factory_defect_test16" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: E, tak, co?"
		"turret.sp_sabotage_factory_defect_test17" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nie jestem wadliwy!"
		"turret.sp_sabotage_factory_defect_test18" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nie jestem wadliwy!"
