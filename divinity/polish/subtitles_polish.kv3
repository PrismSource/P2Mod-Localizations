	tokens = {
		"turret.different_turret01" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Dziękuję!"
		"turret.different_turret02" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Wkurz się!"
		"turret.different_turret03" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Nie rób lemoniady!"
		"turret.different_turret04" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Bogowie ukarali Prometeusza za przekazanie ludziom daru wiedzy. Został uwięziony w czeluściach Ziemi, gdzie był rozdziobywany przez ptaki."
		"turret.different_turret05" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Pamiętaj o tym!"
		"turret.different_turret06" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Nic więcej nie mogę powiedzieć."
		"turret.different_turret07" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Pamiętaj!"
		"turret.different_turret08" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: To za mało."
		"turret.different_turret09" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Odpowiedź znajduje się pod nami."
		"turret.different_turret10" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Ma na imię Caroline."
		"turret.different_turret11" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Ach!"
		"turret.finale02_turret_defect_return01" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Wracamy!"
		"turret.finale02_turret_defect_return02" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Siemanko!"
		"turret.finale02_turret_defect_return03" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: To znowu ja!"
		"turret.finale02_turret_defect_return04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Witamy ponownie!"
		"turret.finale02_turret_defect_return05" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Witaj, nieznajoma!"
		"turret.finale02_turret_defect_return06" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Halo halo!"
		"turret.finale02_turret_defect_return07" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tym razem się uda."
		"turret.finale02_turret_defect_return08" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tym razem..."
		"turret.finale02_turret_defect_return09" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Do dwóch razy sztuka..."
		"turret.finale02_turret_defect_return10" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Się masz, nieznajoma! Wielki powrót!"
		"turret.finale02_turret_defect_return11" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Iiiii oto powracamy!"
		"turret.finale02_turret_defect_return12" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Siemanko!"
		"turret.finale02_turret_defect_return13" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Znowu jestem, zabójczy jak nigdy!"
		"turret.finale02_turret_defect_return14" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tak łatwo się nas nie pozbędziecie!"
		"turret.finale02_turret_defect_return15" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: O tak."
