		"turret.finale02_turret_return_defect_goodbye04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Hej, ładny ziemniak!"
		"turret.finale02_turret_return_defect_goodbye05" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Fajny ziemniak!"
