		"turret.finale02_turret_return_defect_goodbye08" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: To była przyjemność!"
		"turret.finale02_turret_return_defect_goodbye09" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Proszę, zabierz mnie ze sobą..."
		"turret.finale02_turret_return_defect_goodbye10" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Ha, daj im popalić, słodziutka!"
		"turret.finale02_turret_return_defect_goodbye11" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Fajnie było, nie?"
		"turret.finale02_turret_return_defect_goodbye12" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Tym razem ty byłaś lepsza."
		"turret.finale02_turret_return_defect_goodbye13" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Trafiony, zatopiony. Brawo, panienko."
		"turret.glados_battle_defect_arrive01" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: To moja wielka szansa!"
		"turret.glados_battle_defect_arrive02" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nie zawiodę cię!"
		"turret.glados_battle_defect_arrive03" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nie pożałujesz tego!"
		"turret.glados_battle_defect_arrive04" = "<font color=\"rgb(197,208,230)\"><low>Uszkodzona wieżyczka: Nadeszła pora, by zepsuta wieżyczka pokazała, na co ją stać!"
