		"turret.turretwitnessdeath01" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Niezły strzał!"
		"turret.turretwitnessdeath02" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Dobra robota!"
		"turret.turretwitnessdeath03" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Potrzebuję wsparcia!"
		"turret.turretwitnessdeath04" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Świetnie celujesz!"
		"turret.turretwitnessdeath05" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Nigdy jej nie lubiłem."
		"turret.turretwitnessdeath06" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Zdarza się."
		"turret.turretwitnessdeath07" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Nikt tu nie zawinił."
		"turret.turretwitnessdeath08" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Ona cię prowokowała."
		"turret.turretwitnessdeath09" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Ojej."
		"turret.turretwitnessdeath10" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Ojejku."
		"turret.turretwitnessdeath11" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Czuję się winny."
		"turret.turretwitnessdeath12" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: W sumie chyba na to zasługiwała."
		"turret.turretwitnessdeath13" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Wszystko widziałem. To był wypadek."
		"turret.turretwitnessdeath14" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Pewnie nic jej nie jest."
		"turret.turretwitnessdeath15" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Odnotowano."
		"npc_floorturret.talkactive" = "<font color=\"rgb(170,240,209)\"><low>Wieżyczka: Aktywna!"
